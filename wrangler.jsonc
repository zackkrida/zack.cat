{
	"compatibility_date": "2026-03-10",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "zack-cat",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{ "pattern": "zack.cat", "custom_domain": true },
		{ "pattern": "www.zack.cat", "custom_domain": true }
	]
}
